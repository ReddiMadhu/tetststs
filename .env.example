# ═══════════════════════════════════════════════════════════════════
#  CAT Modeling Pipeline — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments.
#
#  LOCAL DEVELOPMENT: leave STORAGE_MODE=local (default).
#    - All row data stays in RAM (existing behaviour).
#    - AZURE_* variables are not needed.
#    - AZURE_OPENAI vars needed only if you want LLM features locally.
#
#  AZURE PRODUCTION: set STORAGE_MODE=azure.
#    - Row data goes into DuckDB on Azure File Share.
#    - Original uploads go into Azure Blob Storage.
#    - All AZURE_* variables required.
#
# ═══════════════════════════════════════════════════════════════════

# ── Storage Mode ──────────────────────────────────────────────────
# "local"  → in-memory session dict  (default, zero config)
# "azure"  → DuckDB + Azure Blob     (production)
STORAGE_MODE=local

# ── Azure OpenAI (replaces all Gemini references) ─────────────────
# Required in BOTH local and azure modes if you want LLM features.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Geoapify (geocoding) ───────────────────────────────────────────
GEOAPIFY_API_KEY=your-geoapify-key-here

# ── Session TTL ────────────────────────────────────────────────────
SESSION_TTL_MINUTES=60

# ── DuckDB (only needed when STORAGE_MODE=azure) ──────────────────
# Mount path set in Azure Portal → App Service → Path Mappings.
DUCKDB_PATH=/mnt/azurefiles/pipeline.duckdb

# ── Azure Blob Storage (only needed when STORAGE_MODE=azure) ──────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=catpipeline
